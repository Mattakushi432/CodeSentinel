# ─── Required ─────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# If omitted, a temporary key is auto-generated (sessions reset on each restart).
SECRET_KEY=change-me-with-a-64-char-hex-string

# ─── Database ─────────────────────────────────────────────────────────────────
# Default: SQLite — works out of the box, no extra setup needed.
# PostgreSQL: postgresql+psycopg2://user:password@host/dbname
DATABASE_URL=sqlite:///./data/codesentinel.db

# ─── App URL ──────────────────────────────────────────────────────────────────
# Used for CSRF validation. Set to your public URL in production.
BASE_URL=http://localhost:8000

# ─── LLM Provider ─────────────────────────────────────────────────────────────
# "ollama" (default, fully local) or "groq" (cloud, faster, free tier available)
LLM_PROVIDER=ollama

# Ollama — used when LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=qwen2.5-coder:7b-instruct

# Groq — used when LLM_PROVIDER=groq (get a free key at console.groq.com)
# GROQ_API_KEY=gsk_...
# GROQ_MODEL=llama-3.3-70b-versatile

# ─── Caddy (reverse proxy) ────────────────────────────────────────────────────
# Set to your domain for HTTPS, or leave as "localhost" for local access.
CADDY_DOMAIN=localhost

# ─── Optional ─────────────────────────────────────────────────────────────────
# Fernet key for encrypting Git access tokens at rest.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# ENCRYPTION_KEY=

# Prometheus metrics endpoint bearer token (leave empty to disable)
# METRICS_TOKEN=

# Tuning
MAX_DIFF_LINES=500
WORKER_POLL_INTERVAL=10
LLM_TIMEOUT=300
